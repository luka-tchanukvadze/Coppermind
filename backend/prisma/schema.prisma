generator client {
  provider        = "prisma-client-js"
  // enables relationLoadStrategy: "join" on findMany/findFirst etc.
  previewFeatures = ["relationJoins"]
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid())
  name                 String    @db.VarChar(255)
  email                String    @unique @db.VarChar(255)
  photo                String    @default("default.jpg") @db.VarChar(255)
  role                 Role      @default(user)
  password             String    @db.VarChar(255)
  passwordChangedAt    DateTime?
  passwordResetToken   String?   @db.VarChar(255)
  passwordResetExpires DateTime?
  active               Boolean   @default(true)
  // written on the last-tab disconnect. used by the chat header to show
  // "Last seen X ago" (or "Last seen recently" past 1 day) when offline
  lastSeenAt           DateTime?
  // bumped to now() when the user opens the Friends page. the nav badge counts
  // incoming requests newer than this - so opening Friends clears the dot,
  // facebook-style. null = never opened, so every pending request counts
  friendRequestsSeenAt DateTime?

  userBooks            UserBook[]
  customData           CustomData[]
  sentRequests         FriendConnection[]  @relation("Requester")
  receivedRequests     FriendConnection[]  @relation("Addressee")
  messages             Message[]
  conversations        ConversationParticipant[]
  discussions          Discussion[]
  comments             Comment[]
  likes                Like[]
  activities           Activity[]

  @@map("users")
}

model Book {
  id            String     @id @default(uuid())
  title         String     @unique @db.VarChar(255)
  author        String     @db.VarChar(255)
  genres        String[]
  coverImage    String     @db.VarChar(255)
  externalApiId String?    @db.VarChar(255)

  userBooks     UserBook[]
  activities    Activity[]
  discussions   Discussion[]

  @@map("books")
}

model UserBook {
  id                  String    @id @default(uuid())
  progress            Progress
  isPrivate           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  progressUpdatedAt   DateTime? @updatedAt

  userId              String
  user                User      @relation(fields: [userId], references: [id])
  bookId              String
  book                Book      @relation(fields: [bookId], references: [id])
  customData          CustomData[]

  @@unique([userId, bookId])
  @@map("user_books")
}

model CustomData {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(255)
  content     String
  isPrivate   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  userId      String
  user        User      @relation(fields: [userId], references: [id])
  userBookId  String
  userBook    UserBook   @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  activities  Activity[]

  @@index([userBookId])
  @@map("custom_data")
}

model FriendConnection {
  id            String   @id @default(uuid())
  status        Status   @default(PENDING)
  createdAt     DateTime @default(now())

  requesterId   String
  requester     User     @relation("Requester", fields: [requesterId], references: [id])
  addresseeId   String
  addressee     User     @relation("Addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@map("friend_connections")
}

model Conversation {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())

  participants  ConversationParticipant[]
  messages      Message[]

  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  text            String
  createdAt       DateTime @default(now())

  userId          String
  user            User         @relation(fields: [userId], references: [id])
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  @@index([userId])
  @@map("messages")
}

model ConversationParticipant {
  id              String @id @default(uuid())

  userId          String
  user            User         @relation(fields: [userId], references: [id])
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  // bumped to now() whenever this participant opens the thread. unread =
  // messages from the other person with createdAt > lastReadAt. null = never
  // opened, so every message from the other side counts as unread
  lastReadAt      DateTime?

  @@unique([userId, conversationId])
  @@index([conversationId])
  @@map("conversation_participants")
}

model Discussion {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(255)
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creatorId   String
  creator     User      @relation(fields: [creatorId], references: [id])
  // optional: existing discussions stay null, new ones can be tied to a book
  bookId      String?
  book        Book?     @relation(fields: [bookId], references: [id])
  comments    Comment[]
  likes       Like[]
  activities  Activity[]

  @@index([bookId])
  @@map("discussions")
}

model Comment {
  id            String   @id @default(uuid())
  content       String
  createdAt     DateTime @default(now())

  userId        String
  user          User       @relation(fields: [userId], references: [id])
  discussionId  String
  // cascade so deleting a discussion auto-cleans its comments
  discussion    Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  activities    Activity[]

  @@index([discussionId, createdAt])
  @@map("comments")
}

model Like {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  userId        String
  user          User       @relation(fields: [userId], references: [id])
  discussionId  String
  // cascade so deleting a discussion auto-cleans its likes
  discussion    Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@index([discussionId])
  @@map("likes")
}

enum Role {
  user
  author
  admin
}

enum Progress {
  WANT_TO_READ
  READING
  READ
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
}

model Activity {
  id        String       @id @default(uuid())
  kind      ActivityKind
  createdAt DateTime     @default(now())

  // who did the thing
  userId    String
  user      User         @relation(fields: [userId], references: [id])

  // only one of these has a value, based on the kind
  // if the linked thing is deleted, this row is deleted too
  bookId         String?
  book           Book?       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  discussionId   String?
  discussion     Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  commentId      String?
  comment        Comment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  customDataId   String?
  customData     CustomData? @relation(fields: [customDataId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("activities")
}

enum ActivityKind {
  WANTS_TO_READ
  STARTED_READING
  FINISHED_BOOK
  NEW_DISCUSSION
  DISCUSSION_COMMENT
  PUBLIC_NOTE
}