generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid())
  name                 String    @db.VarChar(255)
  email                String    @unique @db.VarChar(255)
  photo                String    @default("default.jpg") @db.VarChar(255)
  role                 Role      @default(user)
  password             String    @db.VarChar(255)
  passwordChangedAt    DateTime?
  passwordResetToken   String?   @db.VarChar(255)
  passwordResetExpires DateTime?
  active               Boolean   @default(true)

  userBooks            UserBook[]
  customData           CustomData[]
  sentRequests         FriendConnection[]  @relation("Requester")
  receivedRequests     FriendConnection[]  @relation("Addressee")
  messages             Message[]
  conversations        ConversationParticipant[]
  discussions          Discussion[]
  comments             Comment[]
  likes                Like[]

  @@map("users")
}

model Book {
  id            String     @id @default(uuid())
  title         String     @unique @db.VarChar(255)
  author        String     @db.VarChar(255)
  genres        String[]
  coverImage    String     @db.VarChar(255)
  externalApiId String?    @db.VarChar(255)

  userBooks     UserBook[]

  @@map("books")
}

model UserBook {
  id                  String    @id @default(uuid())
  progress            Progress
  isPrivate           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  progressUpdatedAt   DateTime? @updatedAt

  userId              String
  user                User      @relation(fields: [userId], references: [id])
  bookId              String
  book                Book      @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@map("user_books")
}

model CustomData {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(255)
  content     String
  isPrivate   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  userId      String
  user        User      @relation(fields: [userId], references: [id])

  @@map("custom_data")
}

model FriendConnection {
  id            String   @id @default(uuid())
  status        Status   @default(PENDING)
  createdAt     DateTime @default(now())

  requesterId   String
  requester     User     @relation("Requester", fields: [requesterId], references: [id])
  addresseeId   String
  addressee     User     @relation("Addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@map("friend_connections")
}

model Conversation {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())

  participants  ConversationParticipant[]
  messages      Message[]

  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  text            String
  createdAt       DateTime @default(now())

  userId          String
  user            User         @relation(fields: [userId], references: [id])
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

model ConversationParticipant {
  id              String @id @default(uuid())

  userId          String
  user            User         @relation(fields: [userId], references: [id])
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId])
  @@map("conversation_participants")
}

model Discussion {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(255)
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creatorId   String
  creator     User      @relation(fields: [creatorId], references: [id])
  comments    Comment[]
  likes       Like[]

  @@map("discussions")
}

model Comment {
  id            String   @id @default(uuid())
  content       String
  createdAt     DateTime @default(now())

  userId        String
  user          User       @relation(fields: [userId], references: [id])
  discussionId  String
  discussion    Discussion @relation(fields: [discussionId], references: [id])

  @@map("comments")
}

model Like {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  userId        String
  user          User       @relation(fields: [userId], references: [id])
  discussionId  String
  discussion    Discussion @relation(fields: [discussionId], references: [id])

  @@unique([userId, discussionId])
  @@map("likes")
}

enum Role {
  user
  author
  admin
}

enum Progress {
  WANT_TO_READ
  READING
  READ
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
}